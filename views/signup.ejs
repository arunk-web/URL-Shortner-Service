<!DOCTYPE html>
<html lang="en">
<head>
    <!-- <style>
        body{
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }
    </style> -->
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Signup</title>
</head>
<body>

    <%- include('partials/navbar') %>

    <div class="auth-wrapper">
        <div class="auth-card">
            <h2>Create Account</h2>
            <p class="subtitle" > Sign up to start shortening Links</p>

            <% if (locals.error) { %>
                <p class="error-msg"> <%= Invalid email or password %></p>
            <% } %>

            <form action="/user" method="post">
                <div class="form-group">
                    <label>Full Name</label>
                    <input type="text" required name="name" placeholder="Enter name">
                </div>

                <div class="form-group">
                    <label>Email</label>
                    <input type="text" required name="email" placeholder="enter email">
                </div>

                <div class="form-group">
                    <label>Password</label>
                    <input type="password" required name="password" placeholder="enter password">
                </div>

                <button type="submit" class="btn btn-primary auth-submit">Sign up</button>
            </form>

            <p class="auth-footer">
                Already have an account? <a href="/login">Log in</a>
            </p>


        </div>

    </div>
</body>
</html>